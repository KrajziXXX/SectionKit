  "4Q: Wyszukiwanie binarne": {
    "prefix": "4QBinarne",
    "description": "Wyszukiwanie binarne",
    "body": [
      "def wyszukiwanie_binarne(tablica, szukana):",
      "    lewy = 0",
      "    prawy = len(tablica) - 1",
      "",
      "    while lewy <= prawy:",
      "        srodek = (lewy + prawy) // 2",
      "",
      "        if tablica[srodek] == szukana:",
      "            return srodek",
      "        elif tablica[srodek] < szukana:",
      "            lewy = srodek + 1",
      "        else:",
      "            prawy = srodek - 1",
      "",
      "    return -1",
      "",
      "liczby = [1, 3, 5, 7, 9, 12, 15]",
      "print(wyszukiwanie_binarne(liczby, 9))",
      "print(wyszukiwanie_binarne(liczby, 2))"
    ]
  },

