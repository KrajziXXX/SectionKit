      "    lewy = 0",
      "    prawy = len(tablica) - 1",
      "",
      "    while lewy <= prawy:",
      "        srodek = (lewy + prawy) // 2",
      "",
      "        if tablica[srodek] == szukana:",
      "            return srodek",
      "        elif tablica[srodek] < szukana:",
      "            lewy = srodek + 1",
      "        else:",
