  "4QExpressCRUD": {
    "prefix": "4QExpressCRUD",
    "description": "CRUD Express",
    "body": [
      "const express = require('express');",
      "const app = express();",
      "",
      "app.use(express.json());",
      "",
      "let users = [];",
      "",
      "// GET",
      "app.get('/users', (req, res) => {",
      "    res.json(users);",
      "});",
      "",
      "// POST",
      "app.post('/users', (req, res) => {",
      "    const user = {",
      "        id: Date.now(),",
      "        name: req.body.name",
      "    };",
      "",
      "    users.push(user);",
      "    res.json(user);",
      "});",
      "",
      "// PUT",
      "app.put('/users/:id', (req, res) => {",
      "    const id = Number(req.params.id);",
      "",
      "    users = users.map(user =>",
      "        user.id === id",
      "            ? { ...user, name: req.body.name }",
      "            : user",
      "    );",
      "",
      "    res.send('Zaktualizowano');",
      "});",
      "",
      "// DELETE",
      "app.delete('/users/:id', (req, res) => {",
      "    const id = Number(req.params.id);",
      "",
      "    users = users.filter(user => user.id !== id);",
      "",
      "    res.send('Usunięto');",
      "});",
      "",
      "app.listen(3000, () => {",
      "    console.log('Server działa');",
      "});"
    ]
  },

  "4QExpressFullTemplate": {
    "prefix": "4QExpressFullTemplate",
    "description": "Pełny backend Express",
    "body": [
      "const express = require('express');",
      "const cors = require('cors');",
      "const fs = require('fs');",
      "",
      "const app = express();",
      "",
      "app.use(cors());",
      "app.use(express.json());",
      "",
      "// Middleware",
      "app.use((req, res, next) => {",
      "    console.log(`${req.method} ${req.url}`);",
      "    next();",
      "});",
      "",
      "let users = [];",
      "",
      "// GET",
      "app.get('/users', (req, res) => {",
      "    res.json(users);",
      "});",
      "",
      "// GET BY ID",
      "app.get('/users/:id', (req, res) => {",
      "    const id = Number(req.params.id);",
      "    const user = users.find(u => u.id === id);",
      "",
      "    res.json(user);",
      "});",
      "",
      "// POST",
      "app.post('/users', (req, res) => {",
      "    const user = {",
      "        id: Date.now(),",
      "        name: req.body.name",
      "    };",
      "",
      "    users.push(user);",
      "",
      "    fs.writeFileSync('users.json', JSON.stringify(users, null, 2));",
      "",
      "    res.json(user);",
      "});",
      "",
      "// PUT",
      "app.put('/users/:id', (req, res) => {",
      "    const id = Number(req.params.id);",
      "",
      "    users = users.map(user =>",
      "        user.id === id",
      "            ? { ...user, name: req.body.name }",
      "            : user",
      "    );",
      "",
      "    res.send('Użytkownik zaktualizowany');",
      "});",
      "",
      "// DELETE",
      "app.delete('/users/:id', (req, res) => {",
      "    const id = Number(req.params.id);",
      "",
      "    users = users.filter(user => user.id !== id);",
      "",
      "    res.send('Użytkownik usunięty');",
      "});",
      "",
      "app.listen(3000, () => {",
      "    console.log('Server działa na porcie 3000');",
      "});"
    ]
  }
