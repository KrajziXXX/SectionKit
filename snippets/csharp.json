  "WPF C# – pełny CRUD + DataBinding (ListView)": {
    "prefix": "4QWPFcrud!",
    "description": "WPF CRUD + ListView + ObservableCollection – INF04",
    "body": [
      "// ================= XAML (Grid) =================",
      "<StackPanel Margin=\"10\">",
      "  <TextBox x:Name=\"txtNazwa\" Margin=\"5\" />",
      "  <TextBox x:Name=\"txtCena\" Margin=\"5\" />",
      "  <Button Content=\"Dodaj\" Click=\"BtnDodaj_Click\" Margin=\"5\"/>",
      "  <Button Content=\"Usuń\" Click=\"BtnUsun_Click\" Margin=\"5\"/>",
      "  <Button Content=\"Edytuj\" Click=\"BtnEdytuj_Click\" Margin=\"5\"/>",
      "",
      "  <ListView x:Name=\"lvLista\" Margin=\"5\" Height=\"200\">",
      "    <ListView.View>",
      "      <GridView>",
      "        <GridViewColumn Header=\"Nazwa\" DisplayMemberBinding=\"{Binding Nazwa}\" Width=\"150\"/>",
      "        <GridViewColumn Header=\"Cena\" DisplayMemberBinding=\"{Binding Cena}\" Width=\"100\"/>",
      "      </GridView>",
      "    </ListView.View>",
      "  </ListView>",
      "",
      "  <TextBlock x:Name=\"txtBlad\" Foreground=\"Red\"/>",
      "</StackPanel>",
      "",
      "using System.Collections.ObjectModel;",
      "using System.Windows;",
      "",
      "public class Produkt",
      "{",
      "    public int Id { get; set; }",
      "    public string Nazwa { get; set; } = \"\";",
      "    public double Cena { get; set; }",
      "}",
      "",
      "public partial class MainWindow : Window",
      "{",
      "    ObservableCollection<Produkt> lista = new();",
      "    int id = 1;",
      "",
      "    public MainWindow()",
      "    {",
      "        InitializeComponent();",
      "        lvLista.ItemsSource = lista;",
      "    }",
      "",
      "    private void BtnDodaj_Click(object sender, RoutedEventArgs e)",
      "    {",
      "        lista.Add(new Produkt { Id = id++, Nazwa = txtNazwa.Text, Cena = double.Parse(txtCena.Text) });",
      "    }",
      "",
      "    private void BtnUsun_Click(object sender, RoutedEventArgs e)",
      "    {",
      "        if (lvLista.SelectedItem is Produkt p) lista.Remove(p);",
      "    }",
      "",
      "    private void BtnEdytuj_Click(object sender, RoutedEventArgs e)",
      "    {",
      "        if (lvLista.SelectedItem is Produkt p)",
      "        {",
      "            p.Nazwa = txtNazwa.Text;",
      "            p.Cena = double.Parse(txtCena.Text);",
      "            lvLista.Items.Refresh();",
      "        }",
      "    }",
      "}"
    ]
  },

  "WPF – DataBinding INotifyPropertyChanged": {
    "prefix": "4QWPFbinding!",
    "description": "INotifyPropertyChanged + ObservableCollection",
    "body": [
      "using System.ComponentModel;",
      "using System.Runtime.CompilerServices;",
      "using System.Collections.ObjectModel;",
      "using System.Windows;",
      "",
      "public class Produkt : INotifyPropertyChanged",
      "{",
      "    private string nazwa;",
      "    private double cena;",
      "",
      "    public string Nazwa",
      "    {",
      "        get => nazwa;",
      "        set { nazwa = value; OnPropertyChanged(); }",
      "    }",
      "",
      "    public double Cena",
      "    {",
      "        get => cena;",
      "        set { cena = value; OnPropertyChanged(); }",
      "    }",
      "",
      "    public event PropertyChangedEventHandler PropertyChanged;",
      "    void OnPropertyChanged([CallerMemberName] string name = null)",
      "        => PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(name));",
      "}",
      "",
      "public partial class MainWindow : Window",
      "{",
      "    public ObservableCollection<Produkt> Produkty { get; set; } = new();",
      "",
      "    public MainWindow()",
      "    {",
      "        InitializeComponent();",
      "        DataContext = this;",
      "    }",
      "}"
    ]
  },

