  "4Q: Algorytmy – sortowania i wyszukiwania": {
    "prefix": "4QAlgorytmy",
    "description": "Bubble sort, selection sort, insertion sort, quick sort, binary search, Fibonacci, NWD",
    "body": [
      "# ---------- SORTOWANIE BABELKOWE ----------",
      "def bubble_sort(tablica):",
      "    for i in range(len(tablica) - 1):",
      "        for j in range(len(tablica) - 1 - i):",
      "            if tablica[j] > tablica[j + 1]:",
      "                tablica[j], tablica[j + 1] = tablica[j + 1], tablica[j]",
      "",
      "# ---------- SORTOWANIE PRZEZ WYBIERANIE ----------",
      "def selection_sort(tablica):",
      "    for i in range(len(tablica) - 1):",
      "        min_index = i",
      "        for j in range(i + 1, len(tablica)):",
      "            if tablica[j] < tablica[min_index]:",
      "                min_index = j",
      "        tablica[i], tablica[min_index] = tablica[min_index], tablica[i]",
      "",
      "# ---------- SORTOWANIE PRZEZ WSTAWIANIE ----------",
      "def insertion_sort(tablica):",
      "    for i in range(1, len(tablica)):",
      "        klucz = tablica[i]",
      "        j = i - 1",
      "        while j >= 0 and tablica[j] > klucz:",
      "            tablica[j + 1] = tablica[j]",
      "            j -= 1",
      "        tablica[j + 1] = klucz",
      "",
      "# ---------- SORTOWANIE SZYBKIE ----------",
      "def quick_sort(tablica):",
      "    if len(tablica) <= 1:",
      "        return tablica",
      "    pivot = tablica[len(tablica) // 2]",
      "    lewa = [x for x in tablica if x < pivot]",
      "    srodek = [x for x in tablica if x == pivot]",
      "    prawa = [x for x in tablica if x > pivot]",
      "    return quick_sort(lewa) + srodek + quick_sort(prawa)",
      "",
      "# ---------- FIBONACCI ----------",
      "def fibonacci(n):",
      "    if n <= 1: return n",
      "    return fibonacci(n - 1) + fibonacci(n - 2)",
      "",
      "# ---------- NWD (EUKLIDES) ----------",
      "def nwd(a, b):",
      "    while b != 0:",
      "        a, b = b, a % b",
      "    return a",
      "",
      "# ---------- WYSZUKIWANIE BINARNE ----------",
      "def binary_search(tablica, x):",
      "    lewy, prawy = 0, len(tablica) - 1",
      "    while lewy <= prawy:",
      "        srodek = (lewy + prawy) // 2",
      "        if tablica[srodek] == x: return srodek",
      "        elif tablica[srodek] < x: lewy = srodek + 1",
      "        else: prawy = srodek - 1",
      "    return -1",
      "",
      "tab = [5, 2, 9, 1, 5, 6]",
      "bubble_sort(tab)",
      "print('Po sortowaniu:', tab)",
      "print('NWD(48, 18):', nwd(48, 18))",
      "print('Fibonacci(6):', fibonacci(6))",
      "print('Wyszukiwanie binarne (5):', binary_search(tab, 5))"
    ]
  },

