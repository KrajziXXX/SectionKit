  "Algorytmy podstawowe – Python ": {
    "prefix": "4Qalgorytmypython!",
    "description": "Sortowanie, wyszukiwanie, Fibonacci, Euklides, sito – Python",
    "body": [
      "# =======================================",
      "#   ALGORYTMY PODSTAWOWE  PYTHON ",
      "# =======================================",
      "",
      "# ---------- SORTOWANIE BĄBELKOWE ----------",
      "def bubble_sort(tablica):",
      "    for i in range(len(tablica) - 1):",
      "        for j in range(len(tablica) - 1 - i):",
      "            if tablica[j] > tablica[j + 1]:",
      "                tablica[j], tablica[j + 1] = tablica[j + 1], tablica[j]",
      "",
      "# ---------- SORTOWANIE PRZEZ WYBIERANIE ----------",
      "def selection_sort(tablica):",
      "    for i in range(len(tablica) - 1):",
      "        min_index = i",
      "        for j in range(i + 1, len(tablica)):",
      "            if tablica[j] < tablica[min_index]:",
      "                min_index = j",
      "        tablica[i], tablica[min_index] = tablica[min_index], tablica[i]",
      "",
      "# ---------- SORTOWANIE PRZEZ WSTAWIANIE ----------",
      "def insertion_sort(tablica):",
      "    for i in range(1, len(tablica)):",
      "        klucz = tablica[i]",
      "        j = i - 1",
      "        while j >= 0 and tablica[j] > klucz:",
      "            tablica[j + 1] = tablica[j]",
      "            j -= 1",
      "        tablica[j + 1] = klucz",
      "",
      "# ---------- SORTOWANIE SHELLA ----------",
      "def shell_sort(tablica):",
      "    odstęp = len(tablica) // 2",
      "    while odstęp > 0:",
      "        for i in range(odstęp, len(tablica)):",
      "            temp = tablica[i]",
      "            j = i",
      "            while j >= odstęp and tablica[j - odstęp] > temp:",
      "                tablica[j] = tablica[j - odstęp]",
      "                j -= odstęp",
      "            tablica[j] = temp",
      "        odstęp //= 2",
      "",
      "# ---------- SORTOWANIE SZYBKIE (QUICK SORT) ----------",
      "def quick_sort(tablica):",
      "    if len(tablica) <= 1:",
      "        return tablica",
      "    pivot = tablica[len(tablica) // 2]",
      "    lewa = [x for x in tablica if x < pivot]",
      "    srodek = [x for x in tablica if x == pivot]",
      "    prawa = [x for x in tablica if x > pivot]",
      "    return quick_sort(lewa) + srodek + quick_sort(prawa)",
      "",
      "# ---------- CIĄG FIBONACCIEGO ----------",
      "def fibonacci(n):",
      "    if n <= 1:",
      "        return n",
      "    return fibonacci(n - 1) + fibonacci(n - 2)",
      "",
      "# ---------- ALGORYTM EUKLIDESA (NWD) ----------",
      "def nwd(a, b):",
      "    while b != 0:",
      "        a, b = b, a % b",
      "    return a",
      "",
      "# ---------- SITO ERATOSTENESA ----------",
      "def sito_eratostenesa(n):",
      "    pierwsze = [True] * (n + 1)",
      "    pierwsze[0] = pierwsze[1] = False",
      "    for i in range(2, int(n ** 0.5) + 1):",
      "        if pierwsze[i]:",
      "            for j in range(i * i, n + 1, i):",
      "                pierwsze[j] = False",
      "    for i in range(2, n + 1):",
      "        if pierwsze[i]:",
      "            print(i, end=\" \")",
      "    print()",
      "",
      "# ---------- WYSZUKIWANIE LINIOWE ----------",
      "def linear_search(tablica, x):",
      "    for i in range(len(tablica)):",
      "        if tablica[i] == x:",
      "            return i",
      "    return -1",
      "",
      "# ---------- WYSZUKIWANIE LINIOWE Z WARTOWNIKIEM ----------",
      "def sentinel_search(tablica, x):",
      "    tablica.append(x)",
      "    i = 0",
      "    while tablica[i] != x:",
      "        i += 1",
      "    tablica.pop()",
      "    if i < len(tablica):",
      "        return i",
      "    return -1",
      "",
      "# ---------- WYSZUKIWANIE BINARNE ----------",
      "def binary_search(tablica, x):",
      "    lewy = 0",
      "    prawy = len(tablica) - 1",
      "    while lewy <= prawy:",
      "        srodek = (lewy + prawy) // 2",
      "        if tablica[srodek] == x:",
      "            return srodek",
      "        elif tablica[srodek] < x:",
      "            lewy = srodek + 1",
      "        else:",
      "            prawy = srodek - 1",
      "    return -1",
      "",
      "# ---------- PRZYKŁADOWE UŻYCIE ----------",
      "tab = [5, 2, 9, 1, 5, 6]",
      "bubble_sort(tab)",
      "print(\"Po sortowaniu:\", tab)",
      "print(\"NWD(48, 18):\", nwd(48, 18))",
      "print(\"Fibonacci(6):\", fibonacci(6))",
      "print(\"Wyszukiwanie binarne (5):\", binary_search(tab, 5))"
    ]
  },
