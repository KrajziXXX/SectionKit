  "4Q: Klasa abstrakcyjna": {
    "prefix": "4QAbstrakcyjna",
    "description": "Klasa abstrakcyjna z ABC i @abstractmethod",
    "body": [
      "from abc import ABC, abstractmethod",
      "",
      "",
      "class ${1:KlasaAbstrakcyjna}(ABC):",
      "    def __init__(self, ${2:nazwa}):",
      "        self.${2:nazwa} = ${2:nazwa}",
      "",
      "    @abstractmethod",
      "    def dzialanie(self):",
      "        pass",
      "",
      "    @abstractmethod",
      "    def opis(self):",
      "        pass",
      "",
      "    def info(self):",
      "        print(f'Obiekt: {self.${2:nazwa}}')",
      "",
      "",
      "class ${3:Implementacja}(${1:KlasaAbstrakcyjna}):",
      "    def __init__(self, ${2:nazwa}, ${4:wartosc}):",
      "        super().__init__(${2:nazwa})",
      "        self.${4:wartosc} = ${4:wartosc}",
      "",
      "    def dzialanie(self):",
      "        print(f'Działanie: {self.${4:wartosc}}')",
      "",
      "    def opis(self):",
      "        return f'${3:Implementacja} - {self.${2:nazwa}}'",
      "",
      "",
      "obj = ${3:Implementacja}('${5:test}', ${6:42})",
      "obj.dzialanie()",
      "obj.info()",
      "print(obj.opis())"
    ]
  },

  "4Q: Pelny OOP (abstrakcja + dziedziczenie + polimorfizm)": {
    "prefix": "4QPelnyOOP",
    "description": "Abstrakcja + dziedziczenie + polimorfizm razem",
    "body": [
      "from abc import ABC, abstractmethod",
      "",
      "",
      "class ${1:BazaAbstrakcyjna}(ABC):",
      "    def __init__(self, nazwa):",
      "        self.nazwa = nazwa",
      "        self.__id = id(self)",
      "",
      "    def get_id(self):",
      "        return self.__id",
      "",
      "    @abstractmethod",
      "    def wykonaj(self):",
      "        pass",
      "",
      "    def __str__(self):",
      "        return f'[{self.__class__.__name__}] {self.nazwa}'",
      "",
      "",
      "class ${2:KlasaPosrednia}(${1:BazaAbstrakcyjna}):",
      "    def __init__(self, nazwa, kategoria):",
      "        super().__init__(nazwa)",
      "        self.kategoria = kategoria",
      "",
      "    def wykonaj(self):",
      "        print(f'Posrednia: {self.nazwa} [{self.kategoria}]')",
      "",
      "",
      "class ${3:KlasaKoncowa}(${2:KlasaPosrednia}):",
      "    def __init__(self, nazwa, kategoria, poziom):",
      "        super().__init__(nazwa, kategoria)",
      "        self.poziom = poziom",
      "",
      "    def wykonaj(self):",
      "        super().wykonaj()",
      "        print(f'Poziom: {self.poziom}')",
      "",
      "",
      "obiekty = [",
      "    ${2:KlasaPosrednia}('Obiekt1', 'A'),",
      "    ${3:KlasaKoncowa}('Obiekt2', 'B', 3),",
      "]",
      "",
      "for obj in obiekty:",
      "    print(obj)",
      "    obj.wykonaj()",
      "    print('ID:', obj.get_id())",
      "    print()"
    ]
  },

  "4Q: TablicaLiczb (sortowanie, prywatna metoda, klasa)": {
    "prefix": "4QTablicaLiczb",
    "description": "Klasa TablicaLiczb – sortowanie malejaco, prywatna metoda, wczytywanie",
    "body": [
      "class TablicaLiczb:",
      "    def __init__(self):",
      "        self.liczby = []",
      "",
      "    def wczytaj_dane(self):",
      "        print('Podaj 10 liczb calkowitych:')",
      "        for i in range(10):",
      "            liczba = int(input(f'Liczba {i+1}: '))",
      "            self.liczby.append(liczba)",
      "",
      "    def sortuj_malejaco(self):",
      "        n = len(self.liczby)",
      "        for i in range(n - 1):",
      "            max_idx = i",
      "            for j in range(i + 1, n):",
      "                if self.liczby[j] > self.liczby[max_idx]:",
      "                    max_idx = j",
      "            self.liczby[i], self.liczby[max_idx] = self.liczby[max_idx], self.liczby[i]",
      "",
      "    def __znajdz_max(self):",
      "        max_wartosc = self.liczby[0]",
      "        for liczba in self.liczby:",
      "            if liczba > max_wartosc:",
      "                max_wartosc = liczba",
      "        return max_wartosc",
      "",
      "    def wyswietl(self):",
      "        print('Posortowana tablica (malejaco):')",
      "        for liczba in self.liczby:",
      "            print(liczba)",
      "        print('Najwieksza wartosc:', self.__znajdz_max())",
      "",
      "",
      "tab = TablicaLiczb()",
      "tab.wczytaj_dane()",
      "tab.sortuj_malejaco()",
      "tab.wyswietl()"
    ]
  },

