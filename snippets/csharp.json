  "WPF Exam – Dodaj Pracownika – C# code-behind": {
    "prefix": "examWPFcs!",
    "description": "Logika C# okna Dodaj Pracownika (egzamin)",
    "body": [
      "using System.Windows;",
      "using System.Windows.Controls;",
      "",
      "namespace DodajPracownika",
      "{",
      "    public partial class MainWindow : Window",
      "    {",
      "        private string haslo = \"\";",
      "",
      "        public MainWindow()",
      "        {",
      "            InitializeComponent();",
      "        }",
      "",
      "        private void btnGeneruj_Click(object sender, RoutedEventArgs e)",
      "        {",
      "            // Pule znaków zgodnie z treścią zadania",
      "            string male    = \"abcdefghijklmnopqrstuvwxyz\";",
      "            string wielkie = \"ABCDEFGHIJKLMNOPQRSTUVWXYZ\";",
      "            string cyfry   = \"0123456789\";",
      "            string spec    = \"!@#$%&*()_+=\";",
      "",
      "            string pula = \"\";",
      "            if (chkMaleWielkie.IsChecked == true) pula += male + wielkie;",
      "            if (chkCyfry.IsChecked      == true) pula += cyfry;",
      "            if (chkSpecjalne.IsChecked  == true) pula += spec;",
      "",
      "            if (pula == \"\")",
      "            {",
      "                MessageBox.Show(\"Zaznacz co najmniej jedną opcję!\");",
      "                return;",
      "            }",
      "",
      "            int n = int.Parse(txtIleZnakow.Text);",
      "            Random los = new Random();",
      "            haslo = \"\";",
      "",
      "            // Uproszczenie: pierwszy znak zawsze ze znaków specjalnych (jeśli zaznaczono)",
      "            if (chkSpecjalne.IsChecked == true)",
      "                haslo += spec[los.Next(spec.Length)];",
      "",
      "            // Reszta znaków losowana z całej puli",
      "            while (haslo.Length < n)",
      "                haslo += pula[los.Next(pula.Length)];",
      "",
      "            MessageBox.Show(haslo);",
      "        }",
      "",
      "        private void btnZatwierdz_Click(object sender, RoutedEventArgs e)",
      "        {",
      "            string imie       = txtImie.Text;",
      "            string nazwisko   = txtNazwisko.Text;",
      "            string stanowisko = (cmbStanowisko.SelectedItem as ComboBoxItem)",
      "                                ?.Content.ToString();",
      "",
      "            MessageBox.Show(",
      "                $\"Dane pracownika: {imie} {nazwisko} {stanowisko} Hasło: {haslo}\");",
      "        }",
      "    }",
      "}"
    ]
  }
