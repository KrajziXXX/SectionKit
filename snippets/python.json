  "Python – wczytywanie rekordów z pliku (albumy)": {
    "prefix": "4QalbumyPlik!",
    "description": "Python: obiekt, lista rekordów, wczytanie z pliku, wyświetlanie",
    "body": [
      "# =======================================",
      "#    – DANE STRUKTURALNE Z PLIKU",
      "#   Python – podejście obiektowe",
      "# =======================================",
      "",
      "# ---------- KLASA (STRUKTURA REKORDU) ----------",
      "# Każdy rekord albumu ma swoje pola",
      "",
      "class Album:",
      "    def __init__(self, wykonawca, tytul, liczba_utworow, pobrania):",
      "        self.wykonawca = wykonawca            # string",
      "        self.tytul = tytul                    # string",
      "        self.liczba_utworow = liczba_utworow  # int",
      "        self.pobrania = pobrania              # int (min. 32-bit)",
      "",
      "",
      "# ---------- FUNKCJA WCZYTUJĄCA DANE Z PLIKU ----------",
      "# Wczytuje WSZYSTKIE rekordy z pliku Data.txt",
      "",
      "def wczytaj_albumy(nazwa_pliku):",
      "    albumy = []   # lista (tablica) rekordów",
      "",
      "    with open(nazwa_pliku, \"r\", encoding=\"utf-8\") as plik:",
      "        linie = plik.readlines()",
      "",
      "    i = 0",
      "    while i < len(linie):",
      "        wykonawca = linie[i].strip()",
      "        tytul = linie[i + 1].strip()",
      "        liczba_utworow = int(linie[i + 2].strip())",
      "        pobrania = int(linie[i + 3].strip())",
      "",
      "        album = Album(wykonawca, tytul, liczba_utworow, pobrania)",
      "        albumy.append(album)",
      "",
      "        i += 4   # przejście do następnego rekordu",
      "",
      "    return albumy",
      "",
      "",
      "# ---------- FUNKCJA WYŚWIETLAJĄCA DANE ----------",
      "# Wyświetla tyle rekordów, ile zostało wczytanych",
      "",
      "def wyswietl_albumy(albumy):",
      "    for album in albumy:",
      "        print(album.wykonawca)",
      "        print(f\"\\\"{album.tytul}\\\"\")",
      "        print(album.liczba_utworow)",
      "        print(album.pobrania)",
      "        print()  # pusta linia między rekordami",
      "",
      "",
      "# ---------- PROGRAM GŁÓWNY ----------",
      "",
      "lista_albumow = wczytaj_albumy(\"Data.txt\")",
      "wyswietl_albumy(lista_albumow)"
