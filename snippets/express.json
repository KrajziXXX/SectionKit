{
  "4QExpressSetupGuide": {
    "prefix": "4QExpressSetupGuide",
    "description": "Instrukcja krok po kroku jak utworzyć projekt Express (Node.js)",
    "body": [
      "// ===============================",
      "// 1. TWORZENIE PROJEKTU",
      "// ===============================",
      "mkdir my-express-app",
      "cd my-express-app",
      "",
      "// ===============================",
      "// 2. INICJALIZACJA NODE",
      "// ===============================",
      "npm init -y",
      "",
      "// ===============================",
      "// 3. INSTALACJA BIBLIOTEK",
      "// ===============================",
      "npm install express cors mysql2",
      "",
      "// (opcjonalnie auto restart serwera)",
      "npm install nodemon --save-dev",
      "",
      "// ===============================",
      "// 4. TWORZENIE PLIKU GŁÓWNEGO",
      "// ===============================",
      "touch server.js",
      "",
      "// STRUKTURA PROJEKTU:",
      "// my-express-app/",
      "// ├── node_modules/",
      "// ├── server.js",
      "// ├── package.json",
      "// └── package-lock.json",
      "",
      "// ===============================",
      "// 5. URUCHAMIANIE SERWERA",
      "// ===============================",
      "node server.js",
      "",
      "// lub (jeśli nodemon):",
      "// npx nodemon server.js",
      "",
      "// ===============================",
      "// 6. PRZYDATNY SCRIPT (package.json)",
      "// ===============================",
      "// \"scripts\": {",
      "//   \"start\": \"node server.js\",",
      "//   \"dev\": \"nodemon server.js\"",
      "// }"
    ]
  },
