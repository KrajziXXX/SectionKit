  "Kotlin – podstawowa klasa": {
    "prefix": "4QKotlinClass",
    "description": "Podstawowa klasa w Kotlinie – INF04",
    "body": [
      "class Person(val name: String, val age: Int) {",
      "    fun greet() {",
      "        println(\"Hello, my name is $name and I am $age years old.\")",
      "    }",
      "}"
    ]
  },

  "4Qkotlin!MainActivity": {
    "prefix": "4QkotlinMainActivity",
    "description": "MainActivity: Button, EditText, ListView, AlertDialog, Toast, Intent",
    "body": [
      "import android.content.Intent",
      "import android.os.Bundle",
      "import android.widget.*",
      "import androidx.appcompat.app.AlertDialog",
      "import androidx.appcompat.app.AppCompatActivity",
      "",
      "class MainActivity : AppCompatActivity() {",
      "    override fun onCreate(savedInstanceState: Bundle?) {",
      "        super.onCreate(savedInstanceState)",
      "        setContentView(R.layout.activity_main)",
      "",
      "        val button = findViewById<Button>(R.id.button)",
      "        val editText = findViewById<EditText>(R.id.editText)",
      "        val listView = findViewById<ListView>(R.id.listView)",
      "",
      "        button.setOnClickListener {",
      "            val text = editText.text.toString()",
      "            Toast.makeText(this, \"Clicked: $text\", Toast.LENGTH_SHORT).show()",
      "        }",
      "",
      "        val items = listOf(\"Item 1\", \"Item 2\", \"Item 3\")",
      "        val adapter = ArrayAdapter(this, android.R.layout.simple_list_item_1, items)",
      "        listView.adapter = adapter",
      "",
      "        listView.setOnItemClickListener { _, _, position, _ ->",
      "            val selectedItem = items[position]",
      "            AlertDialog.Builder(this)",
      "                .setTitle(\"Selected Item\")",
      "                .setMessage(selectedItem)",
      "                .setPositiveButton(\"OK\", null)",
      "                .show()",
      "        }",
      "    }",
      "}"
    ]
  },

  "4QRecyclerView": {
    "prefix": "4QRecyclerView",
    "description": "RecyclerView + Adapter + ViewHolder + onClick/longClick",
    "body": [
      "import android.view.LayoutInflater",
      "import android.view.View",
      "import android.view.ViewGroup",
      "import android.widget.TextView",
      "import androidx.recyclerview.widget.RecyclerView",
      "",
      "class MyAdapter(private val items: List<String>, private val onClick: (String) -> Unit) : RecyclerView.Adapter<MyAdapter.ViewHolder>() {",
      "",
      "    class ViewHolder(view: View) : RecyclerView.ViewHolder(view) {",
      "        val textView: TextView = view.findViewById(R.id.textView)",
      "    }",
      "",
      "    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {",
      "        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_view, parent, false)",
      "        return ViewHolder(view)",
      "    }",
      "",
      "    override fun onBindViewHolder(holder: ViewHolder, position: Int) {",
      "        val item = items[position]",
      "        holder.textView.text = item",
      "        holder.itemView.setOnClickListener { onClick(item) }",
      "    }",
      "",
      "    override fun getItemCount() = items.size",
      "}"
    ]
  },

  "4QIntent": {
    "prefix": "4QIntent",
    "description": "Intent jawny + putExtra/getExtra, intent niejawny (URL, tel, mail)",
    "body": [
      "// Jawny",
      "val intent = Intent(this, SecondActivity::class.java)",
      "intent.putExtra(\"key\", \"value\")",
      "startActivity(intent)",
      "",
      "// Odbiór w SecondActivity",
      "val value = intent.getStringExtra(\"key\")",
      "",
      "// Niejawny",
      "val urlIntent = Intent(Intent.ACTION_VIEW, Uri.parse(\"https://example.com\"))",
      "startActivity(urlIntent)",
      "",
      "val telIntent = Intent(Intent.ACTION_DIAL, Uri.parse(\"tel:123456789\"))",
      "startActivity(telIntent)",
      "",
      "val mailIntent = Intent(Intent.ACTION_SENDTO).apply {",
      "    data = Uri.parse(\"mailto:example@example.com\")",
      "    putExtra(Intent.EXTRA_SUBJECT, \"Subject\")",
      "    putExtra(Intent.EXTRA_TEXT, \"Body\")",
      "}",
      "startActivity(mailIntent)"
    ]
  },

  "4QSharedPrefs": {
    "prefix": "4QSharedPrefs",
    "description": "SharedPreferences: zapis, odczyt, usuwanie",
    "body": [
      "val sharedPreferences = getSharedPreferences(\"MyPrefs\", MODE_PRIVATE)",
      "",
      "// Zapis",
      "sharedPreferences.edit().putString(\"key\", \"value\").apply()",
      "",
      "// Odczyt",
      "val value = sharedPreferences.getString(\"key\", \"default\")",
      "",
      "// Usuwanie",
      "sharedPreferences.edit().remove(\"key\").apply()"
    ]
  },

  "4QKotlinBasics": {
    "prefix": "4QKotlinBasics",
    "description": "Pętle, kolekcje, null safety (?., ?:, !!), wyjątki",
    "body": [
      "// Pętle",
      "for (i in 1..10) println(i)",
      "",
      "// Kolekcje",
      "val list = listOf(1, 2, 3)",
      "val mutableList = mutableListOf(1, 2, 3)",
      "",
      "// Null safety",
      "val nullable: String? = null",
      "println(nullable?.length ?: \"Brak wartości\")",
      "",
      "// Wyjątki",
      "try {",
      "    val result = 10 / 0",
      "} catch (e: ArithmeticException) {",
      "    println(\"Nie można dzielić przez zero\")",
      "}"
    ]
  },

  "4QKotlinDialogs": {
    "prefix": "4QKotlinDialogs",
    "description": "AlertDialog (Tak/Nie, lista, z EditText), Toast, Snackbar",
    "body": [
      "// AlertDialog",
      "AlertDialog.Builder(this)",
      "    .setTitle(\"Title\")",
      "    .setMessage(\"Message\")",
      "    .setPositiveButton(\"Yes\") { _, _ -> println(\"Yes clicked\") }",
      "    .setNegativeButton(\"No\", null)",
      "    .show()",
      "",
      "// Toast",
      "Toast.makeText(this, \"Hello, Toast!\", Toast.LENGTH_SHORT).show()",
      "",
      "// Snackbar",
      "Snackbar.make(findViewById(android.R.id.content), \"Hello, Snackbar!\", Snackbar.LENGTH_SHORT).show()"
    ]
  },

  "4QListDrawable": {
    "prefix": "4QListDrawable",
    "description": "ListView z ikonami drawable + niestandardowy adapter",
    "body": [
      "// Adapter",
      "class CustomAdapter(private val context: Context, private val items: List<Item>) : BaseAdapter() {",
      "    override fun getCount() = items.size",
      "    override fun getItem(position: Int) = items[position]",
      "    override fun getItemId(position: Int) = position.toLong()",
      "    override fun getView(position: Int, convertView: View?, parent: ViewGroup): View {",
      "        val view = convertView ?: LayoutInflater.from(context).inflate(R.layout.list_item, parent, false)",
      "        val item = items[position]",
      "        view.findViewById<ImageView>(R.id.icon).setImageResource(item.iconResId)",
      "        view.findViewById<TextView>(R.id.text).text = item.text",
      "        return view",
      "    }",
      "}"
    ]
  },

  "4QSpinner": {
    "prefix": "4QSpinner",
    "description": "Spinner (dropdown) z ArrayAdapter i obsługą wyboru",
    "body": [
      "val spinner = findViewById<Spinner>(R.id.spinner)",
      "val items = listOf(\"Item 1\", \"Item 2\", \"Item 3\")",
      "val adapter = ArrayAdapter(this, android.R.layout.simple_spinner_item, items)",
      "adapter.setDropDownViewResource(android.R.layout.simple_spinner_dropdown_item)",
      "spinner.adapter = adapter",
      "",
      "spinner.onItemSelectedListener = object : AdapterView.OnItemSelectedListener {",
      "    override fun onItemSelected(parent: AdapterView<*>, view: View?, position: Int, id: Long) {",
      "        val selectedItem = items[position]",
      "        println(\"Selected: $selectedItem\")",
      "    }",
      "",
      "    override fun onNothingSelected(parent: AdapterView<*>) {",
      "        println(\"Nothing selected\")",
      "    }",
      "}"
    ]
  },
  "4QDrawableGallery": {
    "prefix": "4QDrawableGallery",
    "description": "Galeria drawable – przewijanie obrazów w przód i w tył (Next/Previous)",
    "body": [
      "import android.os.Bundle",
      "import android.widget.Button",
      "import android.widget.ImageView",
      "import androidx.appcompat.app.AppCompatActivity",
      "",
      "class MainActivity : AppCompatActivity() {",
      "",
      "    private val images = listOf(",
      "        R.drawable.img1,",
      "        R.drawable.img2,",
      "        R.drawable.img3,",
      "        R.drawable.img4",
      "    )",
      "",
      "    private var index = 0",
      "",
      "    override fun onCreate(savedInstanceState: Bundle?) {",
      "        super.onCreate(savedInstanceState)",
      "        setContentView(R.layout.activity_main)",
      "",
      "        val imageView = findViewById<ImageView>(R.id.imageView)",
      "        val btnNext = findViewById<Button>(R.id.btnNext)",
      "        val btnPrev = findViewById<Button>(R.id.btnPrev)",
      "",
      "        imageView.setImageResource(images[index])",
      "",
      "        btnNext.setOnClickListener {",
      "            index = (index + 1) % images.size",
      "            imageView.setImageResource(images[index])",
      "        }",
      "",
      "        btnPrev.setOnClickListener {",
      "            index = if (index - 1 < 0) images.size - 1 else index - 1",
      "            imageView.setImageResource(images[index])",
      "        }",
      "    }",
      "}"
    ]
  },

  "4QDiceDisableGame": {
    "prefix": "4QDiceDisableGame",
    "description": "Gra w kości – losowanie + blokowanie kości (alpha 0.5 + disable)",
    "body": [
      "import android.os.Bundle",
      "import android.widget.Button",
      "import android.widget.ImageView",
      "import android.widget.TextView",
      "import androidx.appcompat.app.AppCompatActivity",
      "import kotlin.random.Random",
      "",
      "class MainActivity : AppCompatActivity() {",
      "",
      "    private lateinit var dice: List<ImageView>",
      "    private val values = MutableList(5) { 1 }",
      "    private val enabled = MutableList(5) { true }",
      "",
      "    override fun onCreate(savedInstanceState: Bundle?) {",
      "        super.onCreate(savedInstanceState)",
      "        setContentView(R.layout.activity_main)",
      "",
      "        val rollBtn = findViewById<Button>(R.id.rollBtn)",
      "        val result = findViewById<TextView>(R.id.resultText)",
      "",
      "        dice = listOf(",
      "            findViewById(R.id.dice1),",
      "            findViewById(R.id.dice2),",
      "            findViewById(R.id.dice3),",
      "            findViewById(R.id.dice4),",
      "            findViewById(R.id.dice5)",
      "        )",
      "",
      "        dice.forEachIndexed { i, img ->",
      "            img.setOnClickListener {",
      "                enabled[i] = false",
      "                img.alpha = 0.5f",
      "                img.isEnabled = false",
      "            }",
      "        }",
      "",
      "        rollBtn.setOnClickListener {",
      "            var sum = 0",
      "",
      "            for (i in dice.indices) {",
      "                if (enabled[i]) {",
      "                    values[i] = Random.nextInt(1, 7)",
      "                    sum += values[i]",
      "                }",
      "            }",
      "",
      "            result.text = \"Wynik gry: $sum\"",
      "        }",
      "    }",
      "}"
    ]
  }
}
