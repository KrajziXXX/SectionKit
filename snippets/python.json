  "4QINF04SortowanieMalejaco": {
    "prefix": "4QINF04SortowanieMalejaco",
    "description": "INF04 – sortowanie malejące bez gotowych funkcji",
    "body": [
      "class TablicaLiczb:",
      "    def __init__(self):",
      "        self.liczby = []",
      "",
      "    def wczytaj_dane(self):",
      "        print('Podaj 10 liczb całkowitych:')",
      "",
      "        for i in range(10):",
      "            liczba = int(input(f'Liczba {i + 1}: '))",
      "            self.liczby.append(liczba)",
      "",
      "    def sortuj_malejaco(self):",
      "        n = len(self.liczby)",
      "",
      "        for i in range(n - 1):",
      "            max_idx = i",
      "",
      "            for j in range(i + 1, n):",
      "                if self.liczby[j] > self.liczby[max_idx]:",
      "                    max_idx = j",
      "",
      "            self.liczby[i], self.liczby[max_idx] = self.liczby[max_idx], self.liczby[i]",
      "",
      "    def znajdz_max(self):",
      "        max_wartosc = self.liczby[0]",
      "",
      "        for liczba in self.liczby:",
      "            if liczba > max_wartosc:",
      "                max_wartosc = liczba",
      "",
      "        return max_wartosc",
      "",
      "    def wyswietl(self):",
      "        print('Posortowana tablica:')",
      "",
      "        for liczba in self.liczby:",
      "            print(liczba)",
      "",
      "        print('Największa wartość:', self.znajdz_max())",
      "",
      "",
      "tab = TablicaLiczb()",
      "tab.wczytaj_dane()",
      "tab.sortuj_malejaco()",
      "tab.wyswietl()"
    ]
  },

