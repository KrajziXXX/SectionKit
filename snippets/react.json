  "4QReactFullTemplate": {
    "prefix": "4QReactFullTemplate",
    "description": "Pełny szablon React: useState, useEffect, fetch, formularz",
    "body": [
      "import React, { useState, useEffect } from 'react';",
      "",
      "const App = () => {",
      "    const [data, setData] = useState([]);",
      "    const [loading, setLoading] = useState(true);",
      "    const [error, setError] = useState(null);",
      "    const [text, setText] = useState('');",
      "",
      "    useEffect(() => {",
      "        const fetchData = async () => {",
      "            try {",
      "                const response = await fetch('${1:https://jsonplaceholder.typicode.com/users}');",
      "                const result = await response.json();",
      "                setData(result);",
      "            } catch (err) {",
      "                setError(err.message);",
      "            } finally {",
      "                setLoading(false);",
      "            }",
      "        };",
      "",
      "        fetchData();",
      "    }, []);",
      "",
      "    const handleSubmit = (e) => {",
      "        e.preventDefault();",
      "",
      "        const newItem = {",
      "            id: Date.now(),",
      "            name: text",
      "        };",
      "",
      "        setData([...data, newItem]);",
      "        setText('');",
      "    };",
      "",
      "    return (",
      "        <div>",
      "            <h1>React App</h1>",
      "",
      "            {loading && <p>Loading...</p>}",
      "            {error && <p>Error: {error}</p>}",
      "",
      "            <form onSubmit={handleSubmit}>",
      "                <input",
      "                    type='text'",
      "                    value={text}",
      "                    onChange={(e) => setText(e.target.value)}",
      "                    placeholder='Enter text'",
      "                />",
      "",
      "                <button type='submit'>Add</button>",
      "            </form>",
      "",
      "            <ul>",
      "                {data.map((item) => (",
      "                    <li key={item.id}>",
      "                        {item.name}",
      "                    </li>",
      "                ))}",
      "            </ul>",
      "        </div>",
      "    );",
      "};",
      "",
      "export default App;"
    ]
  },

  "4QUseState": {
    "prefix": "4QUseState",
    "description": "Przykład useState",
    "body": [
      "import React, { useState } from 'react';",
      "",
      "const App = () => {",
      "    const [count, setCount] = useState(0);",
      "    const [text, setText] = useState('');",
      "",
      "    return (",
      "        <div>",
      "            <h1>{count}</h1>",
      "",
      "            <button onClick={() => setCount(count + 1)}>",
      "                Increment",
      "            </button>",
      "",
      "            <input",
      "                type='text'",
      "                value={text}",
      "                onChange={(e) => setText(e.target.value)}",
      "            />",
      "",
      "            <p>{text}</p>",
      "        </div>",
      "    );",
      "};",
      "",
      "export default App;"
    ]
  },

  "4QFetch": {
    "prefix": "4QFetch",
    "description": "useEffect + fetch API",
    "body": [
      "import React, { useEffect, useState } from 'react';",
      "",
      "const App = () => {",
      "    const [data, setData] = useState([]);",
      "    const [loading, setLoading] = useState(true);",
      "    const [error, setError] = useState(null);",
      "",
      "    useEffect(() => {",
      "        const fetchData = async () => {",
      "            try {",
      "                const response = await fetch('${1:https://jsonplaceholder.typicode.com/posts}');",
      "                const result = await response.json();",
      "                setData(result);",
      "            } catch (err) {",
      "                setError(err.message);",
      "            } finally {",
      "                setLoading(false);",
      "            }",
      "        };",
      "",
      "        fetchData();",
      "    }, []);",
      "",
      "    return (",
      "        <div>",
      "            <h1>Fetch Example</h1>",
      "",
      "            {loading && <p>Loading...</p>}",
      "            {error && <p>Error: {error}</p>}",
      "",
      "            <ul>",
      "                {data.map((item) => (",
      "                    <li key={item.id}>{item.title}</li>",
      "                ))}",
      "            </ul>",
      "        </div>",
      "    );",
      "};",
      "",
      "export default App;"
    ]
  },

  "4QMapFilter": {
    "prefix": "4QMapFilter",
    "description": "Map, filter, sort",
    "body": [
      "const items = [",
      "    { id: 1, name: 'Laptop', price: 3000 },",
      "    { id: 2, name: 'Mouse', price: 100 },",
      "    { id: 3, name: 'Keyboard', price: 200 }",
      "];",
      "",
      "const filtered = items.filter(item => item.price > 150);",
      "const sorted = items.sort((a, b) => a.price - b.price);",
      "",
      "console.log(filtered);",
      "console.log(sorted);",
      "",
      "filtered.map(item => console.log(item.name));"
    ]
  },

  "4QReducer": {
    "prefix": "4QReducer",
    "description": "Przykład useReducer",
    "body": [
      "import React, { useReducer } from 'react';",
      "",
      "const initialState = {",
      "    count: 0",
      "};",
      "",
      "const reducer = (state, action) => {",
      "    switch (action.type) {",
      "        case 'increment':",
      "            return { count: state.count + 1 };",
      "",
      "        case 'decrement':",
      "            return { count: state.count - 1 };",
      "",
      "        default:",
      "            return state;",
      "    }",
      "};",
      "",
      "const App = () => {",
      "    const [state, dispatch] = useReducer(reducer, initialState);",
      "",
      "    return (",
      "        <div>",
      "            <h1>{state.count}</h1>",
      "",
      "            <button onClick={() => dispatch({ type: 'increment' })}>",
      "                +",
      "            </button>",
      "",
      "            <button onClick={() => dispatch({ type: 'decrement' })}>",
      "                -",
      "            </button>",
      "        </div>",
      "    );",
      "};",
      "",
      "export default App;"
    ]
  }
}
