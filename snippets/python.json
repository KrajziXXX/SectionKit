  "4Q: Sortowanie rosnaco (selection sort)": {
    "prefix": "4QSortowanieRosnaco",
    "description": "Sortowanie rosnaco – selection sort (funkcja)",
    "body": [
      "def sortuj_rosnaco(lista):",
      "    n = len(lista)",
      "    for i in range(n - 1):",
      "        min_idx = i",
      "        for j in range(i + 1, n):",
      "            if lista[j] < lista[min_idx]:",
      "                min_idx = j",
      "        lista[i], lista[min_idx] = lista[min_idx], lista[i]",
      "    return lista",
      "",
      "liczby = [${1:5, 3, 8, 1, 9, 2}]",
      "print(sortuj_rosnaco(liczby))"
    ]
  },

