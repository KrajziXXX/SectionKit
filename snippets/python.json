    "body": [
      "def sortuj_malejaco(lista):",
      "    n = len(lista)",
      "    for i in range(n - 1):",
      "        max_idx = i",
      "        for j in range(i + 1, n):",
      "            if lista[j] > lista[max_idx]:",
